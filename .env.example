# ──────────────────────────────────────────────
# Vanguard Digital Marketing — Environment Variables
# Copy to .env.local and fill in your values
# ──────────────────────────────────────────────

# ── SMTP (Email) ───────────────────────────────
SMTP_HOST=mail.vanguardm.com
SMTP_PORT=465
SMTP_USER=noreply@vanguardm.com
SMTP_PASS=your-email-password

# Where contact form submissions are sent
CONTACT_EMAIL=hello@vanguardm.com

# Sender address (must match an account on your mail server)
FROM_EMAIL=Vanguard Website <noreply@vanguardm.com>

# ── Stripe (Academy Payments) ────────────────
# Get your keys at https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key — used ONLY by scripts/stripe-setup.mjs (never exposed to browser)
# Run: STRIPE_SECRET_KEY=sk_test_xxx npm run stripe:setup
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/vanguardm?schema=public

# ── DataForSEO (keyword backfill scripts) ─────
# Basic-auth token = base64("login:password"). Used by scripts/backfill-*.mjs
DATAFORSEO_AUTH=base64-of-login:password

# ── Auth (NextAuth.js v5) ─────────────────────
NEXTAUTH_URL=https://vanguardm.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ── Google OAuth (optional — leave blank to disable) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to "true" to show the Google Sign-In button on auth pages
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
