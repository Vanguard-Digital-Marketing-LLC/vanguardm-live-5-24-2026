generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── SaaS Enums ──────────────────────────────

enum PlanTier {
  STARTER
  PRO
  ENTERPRISE
}

enum SubStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

// ── Enums ────────────────────────────────────

enum Role {
  ADMIN
  TEAM
  USER
  CLIENT
}

enum TaskStatus {
  NEW
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  PAUSED
  CHURNED
}

enum ServiceType {
  SMA
  PPC
  WEB
  SUPPORT
  SEO
  REPORTING
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum NoteType {
  CALL
  EMAIL
  MEETING
  NOTE
  SUPPORT
}

enum TicketStatus {
  QUEUED
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum OnboardingStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED
  COMPLETED
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum TicketMessageType {
  COMMENT
  AGENT_OUTPUT
  STATUS_CHANGE
  SYSTEM
}

// ── SaaS: Agency (tenant) ────────────────────

model Agency {
  id                  String      @id @default(cuid())
  name                String
  slug                String      @unique   // subdomain: slug.vanguardm.com
  logoUrl             String?
  primaryColor        String?     @default("#10b981")
  accentColor         String?     @default("#f59e0b")
  stripeCustomerId        String?     @unique
  subscriptionId          String?     @unique
  subscriptionStatus      SubStatus   @default(TRIALING)
  planTier                PlanTier    @default(STARTER)
  currentPeriodEnd        DateTime?
  maxClients              Int         @default(5)
  stripeSecretKeyEnc      String?
  stripePublishableKey    String?
  stripeWebhookSecretEnc  String?
  stripeConnectedAt       DateTime?
  smtpHostEnc             String?
  smtpPortEnc             String?
  smtpUserEnc             String?
  smtpPassEnc             String?
  fromEmail               String?
  ownerUserId             String?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  users              User[]
  clients            Client[]
  tasks              Task[]
  leads              Lead[]
  blogPosts          BlogPost[]
  notifications      Notification[]
  teamInvites        TeamInvite[]
  supportTickets     SupportTicket[]
  projects           Project[]
  approvals          Approval[]
  clientOnboardings  ClientOnboarding[]
  multiStepForms     MultiStepForm[]
  contactSubmissions ContactSubmission[]
  conversations      Conversation[]
  servicePayments    ServicePayment[]
  blogTags           BlogTag[]
  blogCategories     BlogCategory[]

  // SEO & Marketing Tools
  keywords           Keyword[]
  keywordLists       KeywordList[]
  serpSnapshots      SerpSnapshot[]
  contentProjects    ContentProject[]
  socialPosts        SocialPost[]
  agentRuns          AgentRun[]
  exitPopupConfigs   ExitPopupConfig[]

  @@index([slug])
}

// ── NextAuth.js adapter tables ───────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  isAdmin       Boolean   @default(false)
  role          Role      @default(USER)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  resetToken          String?
  resetTokenExpiry    DateTime?

  // SaaS: tenant scope (nullable for platform super-admins)
  agencyId      String?
  agency        Agency?   @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([resetToken])
  @@index([agencyId])

  accounts        Account[]
  sessions        Session[]
  coursePurchases CoursePurchase[]
  quizAttempts    QuizAttempt[]
  certificates    Certificate[]
  assignedTasks   Task[]          @relation("TaskAssignee")
  createdTasks    Task[]          @relation("TaskCreator")
  taskComments    TaskComment[]
  notifications   Notification[]
  teamInvitesSent TeamInvite[]    @relation("InvitedBy")
  conversations   Conversation[]
  refreshTokens   RefreshToken[]
  clientNotes      ClientNote[]
  assignedTickets  SupportTicket[]
  ticketMessages   TicketMessage[] @relation("TicketMessages")
  createdOnboardings ClientOnboarding[]

  // Phase 5: Blog
  authorBio       String?   @db.Text
  authorSlug      String?
  blogPosts       BlogPost[]

  // Phase 6: Client Portal
  clientId        String?
  portalClient    Client?   @relation("PortalUsers", fields: [clientId], references: [id])
  clientMessages  ClientMessage[]
  messageReads    ClientMessageRead[] @relation("MessageReads")

  // Phase 8: Lead Capture
  assignedLeads   Lead[]    @relation("LeadAssignee")

  // SEO & Marketing Tools
  socialPosts     SocialPost[] @relation("SocialPostCreator")

  // Approvals
  approvals          Approval[]         @relation("UserApprovals")
  approvalResponses  ApprovalResponse[] @relation("UserApprovalResponses")

  // Portal onboarding & notification preferences
  portalOnboarded         Boolean @default(false)
  emailOnNewReport        Boolean @default(true)
  emailOnApprovalRequest  Boolean @default(true)
  emailOnTicketUpdate     Boolean @default(true)
  emailOnNewMessage       Boolean @default(true)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId])
}

// ── Application tables ───────────────────────

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  service   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  agencyId  String?
  agency    Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([read])
  @@index([createdAt])
  @@index([agencyId])
}

model CoursePurchase {
  id              String   @id @default(cuid())
  userId          String
  courseSlug       String
  stripeSessionId String?  @unique
  stripePaymentId String?
  stripePriceId   String?
  amount          Int
  purchasedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug])
  @@index([userId])
  @@index([courseSlug])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  courseSlug      String
  score          Int
  totalQuestions Int
  passed         Boolean
  answers        Json
  attemptedAt    DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificate Certificate?

  @@index([userId])
  @@index([userId, courseSlug])
}

model Certificate {
  id                String   @id @default(cuid())
  userId            String
  courseSlug         String
  quizAttemptId     String   @unique
  certificateNumber String   @unique @default(cuid())
  issuedAt          DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizAttempt QuizAttempt @relation(fields: [quizAttemptId], references: [id], onDelete: Cascade)

  @@unique([userId, courseSlug])
  @@index([certificateNumber])
}

model ServicePayment {
  id              String   @id @default(cuid())
  stripeSessionId String   @unique
  stripePaymentId String?
  amount          Int
  description     String
  customerEmail   String?
  status          String   @default("completed")
  paidAt          DateTime @default(now())

  agencyId        String?
  agency          Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  @@index([customerEmail])
  @@index([status])
  @@index([paidAt])
  @@index([agencyId])
}

// ── Admin dashboard tables ───────────────────

model TeamInvite {
  id          String    @id @default(cuid())
  email       String
  role        Role      @default(TEAM)
  token       String    @unique @default(cuid())
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  agencyId    String
  agency      Agency    @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@index([agencyId])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(NEW)
  priority    TaskPriority @default(NORMAL)
  category    String?
  clientId    String?
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  serviceType ServiceType?
  dueDate     DateTime?
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User         @relation("TaskCreator", fields: [createdById], references: [id], onDelete: Cascade)
  subtasks    Json?
  comments    TaskComment[]
  agentRuns   AgentRun[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  agencyId    String
  agency      Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([assigneeId])
  @@index([createdById])
  @@index([clientId])
  @@index([serviceType])
  @@index([agencyId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([taskId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([agencyId])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String   @default("New conversation")
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agencyId])
  @@index([clientId])
}

// ── Client CRM tables ────────────────────────

model Client {
  id                String       @id @default(cuid())
  name              String
  domain            String?
  phone             String?
  email             String?
  address           String?      @db.Text
  status            ClientStatus @default(PROSPECT)
  monthlyRetainer   Int?
  dailyBudget       Int?
  billingCycle      BillingCycle @default(MONTHLY)
  contractStart     DateTime?
  contractEnd       DateTime?
  slaResponseHours  Int?         @default(24)
  nimbataProjectId    String?
  gtmContainerId      String?
  cloudflareZoneId    String?
  googleAdsCustomerId String?
  ga4PropertyId       String?
  searchConsoleUrl    String?
  notes             String?      @db.Text
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  agencyId          String
  agency            Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  contacts       ClientContact[]
  services       ClientService[]
  projects       Project[]
  tasks          Task[]
  clientNotes    ClientNote[]
  supportTickets SupportTicket[]
  onboardings    ClientOnboarding[]
  agentRuns      AgentRun[]
  conversations  Conversation[]

  // Phase 6: Client Portal
  portalUsers    User[]           @relation("PortalUsers")
  clientMessages ClientMessage[]
  clientInvites  ClientInvite[]
  messageReads   ClientMessageRead[] @relation("MessageReads")

  // Phase 7: Reports
  clientReports  ClientReport[]
  reportSchedules ReportSchedule[]

  // Approvals
  approvals      Approval[]

  // Phase 8: Lead Capture
  leads          Lead[]

  // Revenue tracking
  jobs           ClientJob[]

  // SEO & Marketing Tools
  keywordLists     KeywordList[]
  contentProjects  ContentProject[]
  socialPosts      SocialPost[]

  @@unique([name, agencyId])
  @@index([status])
  @@index([agencyId])
}

model ClientContact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  role      String   @default("primary")
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([clientId])
}

model ClientService {
  id            String       @id @default(cuid())
  clientId      String
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceType   ServiceType
  status        ClientStatus @default(ACTIVE)
  monthlyBudget Int?
  startDate     DateTime     @default(now())
  createdAt     DateTime     @default(now())

  @@unique([clientId, serviceType])
  @@index([clientId])
}

model Project {
  id            String        @id @default(cuid())
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name          String
  serviceType   ServiceType
  status        ProjectStatus @default(PLANNING)
  description   String?       @db.Text
  startDate     DateTime?
  dueDate       DateTime?
  completedDate DateTime?
  budget        Int?
  tasks         Task[]
  approvals     Approval[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  agencyId      String
  agency        Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
  @@index([serviceType])
  @@index([agencyId])
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NoteType @default(NOTE)
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
}

model SupportTicket {
  id          String       @id @default(cuid())
  clientId    String
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String?      @db.Text
  status      TicketStatus @default(OPEN)
  priority    TaskPriority @default(NORMAL)
  assigneeId  String?
  assignee    User?        @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  source      String?      @default("admin")
  slaDeadline DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  agencyId    String
  agency      Agency       @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  agentRuns   AgentRun[]
  messages    TicketMessage[]

  @@index([clientId])
  @@index([status])
  @@index([assigneeId])
  @@index([agencyId])
}

model TicketMessage {
  id         String            @id @default(cuid())
  ticketId   String
  ticket     SupportTicket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  type       TicketMessageType @default(COMMENT)
  authorId   String?
  author     User?             @relation("TicketMessages", fields: [authorId], references: [id], onDelete: SetNull)
  content    String            @db.Text
  isInternal Boolean           @default(false)
  createdAt  DateTime          @default(now())

  @@index([ticketId])
  @@index([authorId])
}

// ── Agent Runs ──────────────────────────────

model AgentRun {
  id           String         @id @default(cuid())
  ticketId     String?
  ticket       SupportTicket? @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  taskId       String?
  task         Task?          @relation(fields: [taskId], references: [id], onDelete: SetNull)
  agencyId     String?
  agency       Agency?        @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  clientId     String?
  client       Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  kind         String?        // ticket-fix | task-fix | brief-writer | serp-analyst | content-drafter | …
  triggeredBy  String?        // user id of the admin who launched the run
  status       AgentRunStatus @default(QUEUED)
  prompt       String         @db.Text
  output       String?        @db.Text
  filesChanged Json?
  errorMessage String?        @db.Text
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())

  @@index([ticketId])
  @@index([taskId])
  @@index([agencyId])
  @@index([clientId])
  @@index([status])
}

// ── Client Onboarding ───────────────────────

model ClientOnboarding {
  id              String            @id @default(cuid())
  clientId        String
  client          Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  status          OnboardingStatus  @default(DRAFT)
  currentStep     Int               @default(0)
  serviceTypes    ServiceType[]
  token           String            @unique @default(cuid())
  tokenExpiresAt  DateTime
  respondentName  String?
  respondentEmail String?
  createdById     String
  createdBy       User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  submittedAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  agencyId        String
  agency          Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  responses       OnboardingResponse[]
  files           OnboardingFile[]

  @@index([clientId])
  @@index([token])
  @@index([status])
  @@index([createdById])
  @@index([agencyId])
}

model OnboardingResponse {
  id           String           @id @default(cuid())
  onboardingId String
  onboarding   ClientOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  stepKey      String
  data         Json
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([onboardingId, stepKey])
  @@index([onboardingId])
}

model OnboardingFile {
  id           String           @id @default(cuid())
  onboardingId String
  onboarding   ClientOnboarding @relation(fields: [onboardingId], references: [id], onDelete: Cascade)
  category     String
  fileName     String
  storagePath  String
  mimeType     String
  fileSize     Int
  uploadedBy   String?
  createdAt    DateTime         @default(now())

  @@index([onboardingId])
  @@index([category])
}

// ══════════════════════════════════════════════
// Phase 5: Blog / Content Hub
// ══════════════════════════════════════════════

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id              String     @id @default(cuid())
  title           String
  slug            String
  content         String     @db.Text
  excerpt         String?    @db.Text
  coverImage      String?
  authorId        String
  author          User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  status          PostStatus @default(DRAFT)
  publishedAt     DateTime?
  readingTime     Int?
  metaTitle       String?
  metaDescription String?    @db.Text
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  agencyId        String?
  agency          Agency?    @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  tags            BlogPostTag[]
  categories      BlogPostCategory[]

  @@unique([slug, agencyId])
  @@index([authorId])
  @@index([status])
  @@index([publishedAt])
  @@index([agencyId])
}

model BlogTag {
  id       String        @id @default(cuid())
  name     String
  slug     String
  agencyId String?
  agency   Agency?       @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  posts    BlogPostTag[]

  @@unique([slug, agencyId])
  @@index([agencyId])
}

model BlogCategory {
  id       String             @id @default(cuid())
  name     String
  slug     String
  agencyId String?
  agency   Agency?            @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  posts    BlogPostCategory[]

  @@unique([slug, agencyId])
  @@index([agencyId])
}

model BlogPostTag {
  postId String
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model BlogPostCategory {
  postId     String
  post       BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  categoryId String
  category   BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@index([categoryId])
}

// ══════════════════════════════════════════════
// Phase 6: Client Portal
// ══════════════════════════════════════════════

model ClientMessage {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([clientId])
  @@index([userId])
}

model ClientInvite {
  id         String    @id @default(cuid())
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  email      String
  token      String?   @unique
  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([clientId])
  @@index([email])
}

// ══════════════════════════════════════════════
// Phase 7: Reporting Dashboard
// ══════════════════════════════════════════════

enum ReportPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum ReportStatus {
  DRAFT
  PUBLISHED
}

enum ReportSectionType {
  TRAFFIC
  ADS
  SEO
  SOCIAL
  CUSTOM
  MARKETING
  CALLS
}

model ClientReport {
  id        String       @id @default(cuid())
  clientId  String
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title     String
  period    ReportPeriod
  startDate DateTime
  endDate   DateTime
  status    ReportStatus @default(DRAFT)
  summary   String?      @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  sections  ReportSection[]

  @@index([clientId])
  @@index([status])
}

model ReportSection {
  id        String            @id @default(cuid())
  reportId  String
  report    ClientReport      @relation(fields: [reportId], references: [id], onDelete: Cascade)
  type      ReportSectionType
  title     String
  data      Json
  sortOrder Int               @default(0)
  notes     String?           @db.Text
  createdAt DateTime          @default(now())

  @@index([reportId])
}

model ReportSchedule {
  id         String       @id @default(cuid())
  clientId   String
  client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  period     ReportPeriod
  dayOfMonth Int          @default(1)
  sections   Json
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([clientId])
}

// ══════════════════════════════════════════════
// Phase 8: Lead Capture & Scoring
// ══════════════════════════════════════════════

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

model Lead {
  id                      String    @id @default(cuid())
  name                    String
  email                   String
  phone                   String?
  company                 String?
  source                  String?
  status                  LeadStatus @default(NEW)
  score                   Int        @default(0)
  scoreBreakdown          Json?
  // AI assist (on-demand): research brief, augmented intent score + reason, follow-up draft
  researchBrief           String?
  aiScore                 Int?
  aiScoreReason           String?
  followupSubject         String?
  followupBody            String?
  aiAnalyzedAt            DateTime?
  assignedToId            String?
  assignedTo              User?      @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  clientId                String?
  client                  Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  linkedContactSubmissionId String?
  createdAt               DateTime   @default(now())
  updatedAt               DateTime   @updatedAt

  agencyId                String
  agency                  Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  activities              LeadActivity[]
  formResponses           MultiStepFormResponse[]
  chatSessions            ChatSession[]

  @@index([email])
  @@index([status])
  @@index([assignedToId])
  @@index([score])
  @@index([agencyId])
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type      String
  data      Json?
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([type])
}

model MultiStepForm {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  steps     Json
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  responses MultiStepFormResponse[]

  @@index([agencyId])
}

model MultiStepFormResponse {
  id             String        @id @default(cuid())
  formId         String
  form           MultiStepForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  leadId         String?
  lead           Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  data           Json
  completedSteps Int           @default(0)
  isComplete     Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([formId])
  @@index([leadId])
}

model ProcessedStripeEvent {
  id          String   @id // Stripe event.id — globally unique
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model ExitPopupConfig {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  headline    String
  description String   @db.Text
  ctaText     String
  ctaLink     String
  offerType   String?
  isActive    Boolean  @default(true)
  showOnPaths Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agencyId])
}

model ClientMessageRead {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("MessageReads", fields: [userId], references: [id], onDelete: Cascade)
  clientId   String
  client     Client   @relation("MessageReads", fields: [clientId], references: [id], onDelete: Cascade)
  lastReadAt DateTime @default(now())

  @@unique([userId, clientId])
  @@index([userId])
  @@index([clientId])
}

model ChatSession {
  id        String   @id @default(cuid())
  sessionId String   @unique @default(cuid())
  leadId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages  Json
  isAI      Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([sessionId])
}

// ══════════════════════════════════════════════
// Approvals Workflow
// ══════════════════════════════════════════════

enum ApprovalStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
  EXPIRED
}

enum ApprovalAction {
  APPROVED
  REVISION_REQUESTED
  RESUBMITTED
}

enum ApprovalReason {
  NEEDS_CHANGES
  WRONG_DIRECTION
  MISSING_INFO
  OTHER
}

model Approval {
  id          String         @id @default(cuid())
  clientId    String
  projectId   String?
  title       String
  description String         @db.Text
  category    String?
  status      ApprovalStatus @default(PENDING)
  fileUrls    String[]
  dueDate     DateTime?
  createdById String
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  agencyId    String
  agency      Agency             @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project   Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdBy User               @relation("UserApprovals", fields: [createdById], references: [id], onDelete: Cascade)
  responses ApprovalResponse[]

  @@index([clientId, status])
  @@index([createdById])
  @@index([agencyId])
}

model ApprovalResponse {
  id         String         @id @default(cuid())
  approvalId String
  userId     String
  action     ApprovalAction
  reason     ApprovalReason?
  comment    String?        @db.Text
  fileUrls   String[]
  createdAt  DateTime       @default(now())

  approval Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  user     User     @relation("UserApprovalResponses", fields: [userId], references: [id], onDelete: Cascade)

  @@index([approvalId])
}

// ══════════════════════════════════════════════
// Revenue / Job Tracking
// ══════════════════════════════════════════════

model ClientJob {
  id            String   @id @default(cuid())
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  jobNumber     String
  total         Decimal  @default(0) @db.Decimal(12, 2)
  customerName  String?
  leadSource    String?
  team          String?
  commissionPct Decimal  @default(0) @db.Decimal(5, 2)
  payout        Decimal  @default(0) @db.Decimal(12, 2)
  weekNumber    Int
  year          Int
  notes         String?  @db.Text
  jobDate       DateTime?
  createdAt     DateTime @default(now())

  @@index([clientId, year, weekNumber])
  @@index([leadSource])
}

// ══════════════════════════════════════════════
// SEO & Marketing Tools (Ahrefs Explorer)
// ══════════════════════════════════════════════

enum KeywordIntent {
  INFORMATIONAL
  COMMERCIAL
  TRANSACTIONAL
  NAVIGATIONAL
}

enum KeywordSource {
  MANUAL
  GOOGLE_ADS
  AUTOCOMPLETE
  CSV_IMPORT
  AHREFS_IMPORT
}

enum SocialPlatform {
  TWITTER
  LINKEDIN
  FACEBOOK
  INSTAGRAM
}

enum SocialPostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

// ── Keyword Seed Database ───────────────────────
// Shared keyword database per agency. Each keyword is unique per term+agency.
// This is the "seed" that SERP tracking is built on.

model Keyword {
  id               String         @id @default(cuid())
  term             String
  volume           Int?           // Monthly search volume
  difficulty       Int?           // KD 0-100
  cps              Decimal?       @db.Decimal(6, 2) // Clicks per Search
  trafficPotential Int?           // TP (total traffic #1 page gets from all kws)
  globalVolume     Int?
  parentTopic      String?
  serpFeatures     String[]       // Featured Snippet, PAA, Local Pack, etc.
  intent           KeywordIntent?
  source           KeywordSource  @default(MANUAL)
  tags             String[]       // User-defined tags for grouping
  notes            String?        @db.Text
  lastMetricsUpdate DateTime?     // When volume/KD was last refreshed
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  agencyId         String
  agency           Agency         @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  serpResults       SerpResult[]
  listMemberships   KeywordListEntry[]

  @@unique([term, agencyId])
  @@index([agencyId])
  @@index([term])
  @@index([volume])
  @@index([difficulty])
}

// ── Keyword Lists (Collections) ─────────────────
// Lists are like bookmarks/folders for organizing keywords.
// Many-to-many: a keyword can be in multiple lists.

model KeywordList {
  id        String   @id @default(cuid())
  name      String
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  entries   KeywordListEntry[]

  @@index([agencyId])
  @@index([clientId])
}

model KeywordListEntry {
  keywordId String
  keyword   Keyword     @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  listId    String
  list      KeywordList @relation(fields: [listId], references: [id], onDelete: Cascade)
  addedAt   DateTime    @default(now())

  @@id([keywordId, listId])
  @@index([listId])
}

// ── SERP Tracking ───────────────────────────────
// SerpSnapshot = one batch scrape event (e.g. "April 22 scrape")
// SerpResult   = one position in the SERP (keyword × position × URL)
// The domain field is extracted from the URL for fast reverse lookups.

model SerpSnapshot {
  id          String   @id @default(cuid())
  name        String?  // Optional label: "Weekly scrape", "Client audit"
  source      String   @default("manual") // manual, serpapi, dataforseo, csv_import
  keywordCount Int     @default(0)
  resultCount  Int     @default(0)
  scrapedAt   DateTime @default(now())
  createdAt   DateTime @default(now())

  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  results     SerpResult[]

  @@index([agencyId])
  @@index([scrapedAt])
}

model SerpResult {
  id          String       @id @default(cuid())
  snapshotId  String
  snapshot    SerpSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  keywordId   String
  keyword     Keyword      @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  position    Int          // 1-100
  url         String       // Full URL found in SERP
  domain      String       // Extracted: example.com (no protocol, no path)
  title       String
  description String?      @db.Text
  createdAt   DateTime     @default(now())

  @@index([snapshotId])
  @@index([keywordId])
  @@index([domain])
  @@index([url])
  @@index([position])
}

model ContentProject {
  id        String   @id @default(cuid())
  name      String
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  entries   ContentEntry[]

  @@index([agencyId])
  @@index([clientId])
}

model ContentEntry {
  id               String    @id @default(cuid())
  projectId        String
  project          ContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url              String
  title            String
  organicTraffic   Int?
  trafficValue     Decimal?       @db.Decimal(12, 2)
  referringDomains Int?
  domainRating     Int?       // DR 0-100
  wordCount        Int?
  publishedAt      DateTime?
  status           String?    @default("live") // live, broken, redirected
  contentType      String?    // blog, landing, guide, tool, video
  notes            String?    @db.Text
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([projectId])
  @@index([url])
}

model SocialPost {
  id          String           @id @default(cuid())
  platform    SocialPlatform
  content     String           @db.Text
  mediaUrls   String[]
  hashtags    String[]
  scheduledAt DateTime?
  publishedAt DateTime?
  status      SocialPostStatus @default(DRAFT)
  metrics     Json?            // { views, likes, shares, comments, engagement }
  clientId    String?
  client      Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdById String?
  createdBy   User?            @relation("SocialPostCreator", fields: [createdById], references: [id], onDelete: SetNull)
  notes       String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  agencyId    String
  agency      Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([agencyId])
  @@index([clientId])
  @@index([platform])
  @@index([status])
  @@index([scheduledAt])
}
