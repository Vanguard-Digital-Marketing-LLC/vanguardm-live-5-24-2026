# ═══════════════════════════════════════════════
# VanguardM App — .gitignore (Security-Hardened)
# ═══════════════════════════════════════════════

# ── Dependencies ──────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js Build Output ─────────────────────
/.next/
/out/
/build

# ── Testing ───────────────────────────────────
/coverage
/screenshots/
screenshot.mjs
/test-results/
/playwright-report/

# ── Environment & Secrets (CRITICAL) ─────────
.env
.env.*
!.env.example
.env.local
.env.production
.env.staging
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
credentials.json
service-account*.json
*-token
*.secret
.cloudflare-token

# ── TypeScript Build Cache ────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Prisma Generated Client ──────────────────
/lib/generated/prisma

# ── OS & Editor ───────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ── Debug Logs ────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Deployment Artifacts ──────────────────────
deploy.zip
.vercel

# ── Server-Side Only (never commit) ──────────
/form-logs/
/.well-known/

# ── Addon Domain Directories (separate repos) ─
/arcraiders1337.com/
/bvacservices.com/
/cardinal.nu/
/coffeebreakevents.com/
/dbcgamer.com/
/fergrepair.com/
/howdygaragedoors.com/
/yoyogrinder.shop/

# ── Backup Files ──────────────────────────────
*.bak-*
*.backup
*.old
